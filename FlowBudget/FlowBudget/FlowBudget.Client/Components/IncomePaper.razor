@inject IStringLocalizer<SharedResources> L
@using DTO
@using FlowBudget.Client.Components.Dialogs
@using global::DTO
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject HttpClient http

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-6">
        
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">
            <MudIcon Icon=@Icons.Material.Filled.Wallet Class="mx-1" /><b>@L["incomes_title"]</b>
        </MudText>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
        }
        else
        {
            <MudList T="string" Clickable="false" Class="pb-2">
                @foreach (var budget in _budgets)
                {
                    <MudListItem>
                        <MudGrid Items="12" Class="align-center">
                            <MudItem xs="4">
                                <MudText Typo="Typo.body1">@budget.Name</MudText>
                            </MudItem>
                
                            <MudItem xs="4">
                                <MudText Typo="Typo.body1">
                                    @budget.Amount.ToString("N0") @SelectedCurrency
                                </MudText>
                            </MudItem>

                            <MudItem xs="4" Class="d-flex justify-end">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                               OnClick="@(() => EditBudget(budget))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Color="Color.Error" 
                                               OnClick="@(() => DeleteBudget(budget))" />
                            </MudItem>
                        </MudGrid>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>

            // Total
            <MudText Typo="Typo.subtitle1">
                <b>@L["total_income"]</b>
            </MudText>
            <MudPaper Elevation="0" Class="p-2" MaxWidth="" Style="background-color: #2c3034; color: white;">
                <MudText Typo="Typo.h6"><b>@_budgets.Sum(x => x.Amount).ToString("N0") @SelectedCurrency</b></MudText>
            </MudPaper>
            
            <MudStack Row="true" Justify="Justify.FlexStart" Class="mt-6">
                <MudButton Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.Add" 
                           Variant="Variant.Text"
                           Size="Size.Small"
                           OnClick="AddBudget">
                    @L["add_income"]
                </MudButton>
            </MudStack>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public string? AccountId { get; set; }
    
    private List<IncomeDTO> _budgets = new();
    private string SelectedCurrency = "HUF";
    private string? SelectedAccount { get; set; }
    private bool _isLoading = true;

    // Global dialog options as requested
    private readonly DialogOptions _standardOptions = new() 
    { 
        CloseOnEscapeKey = true, 
        MaxWidth = MaxWidth.Small, 
        FullWidth = true 
    };

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(AccountId))
        {
            await LoadIncomes();
        }
    }
    
    private async Task LoadIncomes()
    {
        _isLoading = true;
        try
        {
            var incomes = await http.GetFromJsonAsync<List<IncomeDTO>>($"api/incomes/{AccountId}");
            _budgets = incomes ?? new();
        }
        catch (Exception)
        {
            Snackbar.Add(L["error_loading_incomes"], Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddBudget()
    {
        var parameters = new DialogParameters<AddIncomeDialog>
        {
            { x => x.Currency, SelectedCurrency },
            { x => x.Model, new IncomeDTO() }
        };

        var dialog = await DialogService.ShowAsync<AddIncomeDialog>(L["add_income"], parameters, _standardOptions);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is IncomeDTO newIncome)
        {
            var payload = new CreateIncomeDTO
            {
                AccountId = AccountId,
                Name = newIncome.Name,
                Amount = newIncome.Amount
            };

            var response = await http.PostAsJsonAsync("api/incomes", payload);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(L["save_success"], Severity.Success);
                await LoadIncomes(); // Refetch to ensure sync with server
            }
            else
            {
                Snackbar.Add(L["save_error"], Severity.Error);
            }
        }
    }

    private async Task EditBudget(IncomeDTO budget)
    {
        var modelCopy = new IncomeDTO { Id = budget.Id, Name = budget.Name, Amount = budget.Amount };

        var parameters = new DialogParameters<AddIncomeDialog>
        {
            { x => x.Currency, SelectedCurrency },
            { x => x.Model, modelCopy }
        };

        var dialog = await DialogService.ShowAsync<AddIncomeDialog>(L["edit_income"], parameters, _standardOptions);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is IncomeDTO updated)
        {
            var payload = new EditIncomeDTO { Id = updated.Id, Name = updated.Name, Amount = updated.Amount };
            
            var response = await http.PutAsJsonAsync("api/incomes", payload);
            if (response.IsSuccessStatusCode)
            {
                budget.Name = updated.Name;
                budget.Amount = updated.Amount;
                Snackbar.Add(L["save_success"], Severity.Success);
            }
            else
            {
                Snackbar.Add(L["save_error"], Severity.Error);
            }
        }
    }

    private async Task DeleteBudget(IncomeDTO budget)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L["delete_income_title"] },
            { x => x.ContentText, L["delete_income_confirm_description"] }
        };

        // Confirm dialog uses ExtraSmall usually, but you can use _standardOptions if preferred
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["delete_income_title"], parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var response = await http.DeleteAsync($"api/incomes/{budget.Id}");
            if (response.IsSuccessStatusCode)
            {
                _budgets.Remove(budget);
                Snackbar.Add(L["item_deleted"], Severity.Success);
            }
            else
            {
                Snackbar.Add(L["delete_error"], Severity.Error);
            }
        }
    }
}