@* TODO: Add divisionPlan activation button*@
@inject IStringLocalizer<SharedResources> L
@using System.Diagnostics
@using DTO
@using FlowBudget.Client.Components.Dialogs
@using global::DTO
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject HttpClient http

<style>
    .pockets-paper-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    @@media (max-width: 599px) {
        .pockets-paper-bottom {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
        }

        .pockets-paper-bottom > div {
            justify-content: center;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-6">

        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">
            <MudIcon Icon=@Icons.Material.Filled.BarChart Class="mx-2"/>
            <b>@L["pockets_title"]</b>
        </MudText>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7"/>
        }
        else
        {
            if (!_pockets.Any())
            {
                <MudText Align="Align.Center" Typo="Typo.h6">
                    @L["no_pockets_for_plan"]
                </MudText>
            }
            else
            {
                <MudList T="string" Clickable="false">
                    @foreach (var pocket in _pockets)
                    {
                        <MudListItem>
                            <MudGrid Class="align-center">
                                <MudItem xs="12" sm="4">
                                    <MudText Typo="Typo.body1">@pocket.Name</MudText>
                                </MudItem>

                                <MudItem xs="12" sm="3">
                                    <MudText Typo="Typo.body1">
                                        @((((decimal)pocket.Ration / 100m) * DistributableMoney).ToString("N0")) @SelectedCurrency
                                    </MudText>
                                </MudItem>

                                <MudItem xs="12" sm="2">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">
                                        @pocket.Ration.ToString("N1") %
                                    </MudChip>
                                </MudItem>

                                <MudItem xs="12" sm="3" Class="d-flex justify-end">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   OnClick="@(() => EditPocket(pocket))"/>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                   OnClick="@(() => DeletePocket(pocket))"/>
                                </MudItem>
                            </MudGrid>
                        </MudListItem>
                        <MudDivider/>
                    }
                </MudList>

                @* <MudGrid Class="mt-4 align-center"> *@
                @* <MudItem xs="6"> *@
                @*     <MudText Typo="Typo.subtitle1"><b>@L["total_allocated"]</b></MudText> *@
                @*     <MudPaper Elevation="0" Class="pa-2 mt-1" *@
                @*               Style="background-color: #2c3034; color: white; width: fit-content;"> *@
                @*         <MudText Typo="Typo.h6"><b>@_pockets.Sum(x => x.Money).ToString("N0") @SelectedCurrency</b> *@
                @*         </MudText> *@
                @*     </MudPaper> *@
                @* </MudItem> *@

                // </MudGrid>

                @if (Math.Abs(_pockets.Sum(x => x.Ration) - 100) > 0.01)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-4">
                        @L["ratio_warning_not_100"]
                    </MudAlert>
                }
            }

            // Bottom
            <MudContainer Class="pockets-paper-bottom mt-6 w-100">

                @* --- Left Side --- *@
                <div class="d-flex">
                    <MudGrid Justify="Justify.Center" Spacing="2">
                        <MudItem xs="12" sm="6" Class="d-flex justify-center">
                            <MudButton Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       Variant="Variant.Text"
                                       Size="Size.Small"
                                       OnClick="AddPocket"
                                       Disabled="@(string.IsNullOrEmpty(_selectedPlanId))">
                                @L["add_pocket"]
                            </MudButton>
                        </MudItem>
                        <MudItem xs="12" sm="6" Class="d-flex flex-grow-1">
                            <MudContainer xs="6" Class="d-flex flex-column align-center justify-center flex-grow-1">
                                <MudText Typo="Typo.subtitle2">@L["total_ratio"]</MudText>
                                @{
                                    var totalRatio = _pockets.Sum(x => x.Ration);
                                    var isRatioValid = Math.Abs(totalRatio - 100) < 0.01;
                                }
                                <MudChip T="string"
                                         Color="@(isRatioValid ? Color.Success : Color.Warning)"
                                         Variant="Variant.Filled"
                                         Style="min-width: max-content;">
                                    @totalRatio.ToString("N1") % / 100%
                                </MudChip>
                            </MudContainer>
                        </MudItem>
                    </MudGrid>
                </div>

                @* --- Right Side --- *@
                <div class="d-flex">
                    <MudGrid Justify="Justify.Center" Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string"
                                       Label="@L["select_division_plan"]"
                                       Value="_selectedPlanId"
                                       ValueChanged="OnPlanChanged"
                                       Variant="Variant.Outlined"
                                       FullWidth="false"
                                       Dense="true"
                                       Margin="Margin.Dense"
                                       Class="mx-2"
                                       Style="width: 280px;">
                                @if (!_plans.Any())
                                {
                                    <MudSelectItem Value="@("CREATE_NEW")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Class="mr-2"
                                                     Color="Color.Primary"/>
                                            <MudText Color="Color.Primary"><b>@L["create_first_plan"]</b></MudText>
                                        </div>
                                    </MudSelectItem>
                                }
                                else
                                {
                                    @foreach (var plan in _plans)
                                    {
                                        <MudSelectItem Value="@plan.Id">
                                            <div class="d-flex align-center justify-space-between" style="width: 100%;">
                                                <span>
                                                    @PlanLabel(plan) @(plan.IsActive ? $"({L["active"]})" : "")
                                                </span>
                                                <span @onclick:stopPropagation="true">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                   Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="@(() => DeletePlan(plan))" />
                                                </span>
                                            </div>
                                        </MudSelectItem>
                                    }

                                    @* <MudDivider/> *@
                                    <MudSelectItem Value="@("CREATE_NEW")">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Class="mr-2"
                                                     Color="Color.Primary"/>
                                            <MudText Color="Color.Primary"><b>@L["add_new_plan"]</b></MudText>
                                        </div>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" Class="d-flex justify-center">
                            <MudButton OnClick="() => ActivatePlan()"
                                       Disabled="_selectedPlanId == _plans.SingleOrDefault(p => p.IsActive)?.Id">@L["activate"]</MudButton>
                        </MudItem>
                    </MudGrid>
                </div>
            </MudContainer>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public string? AccountId { get; set; }

    private List<PocketDTO> _pockets = new();
    private List<DivisionPlanDTO> _plans = new();
    private List<IncomeDTO> _incomes = new();
    private List<FixedExpenseDTO> _fixedExpenses = new();
    private decimal DistributableMoney => _incomes.Sum(i => i.Amount) - _fixedExpenses.Sum(e => e.Amount);

    private string? _selectedPlanId;
    [Parameter] public string SelectedCurrency { get; set; } = string.Empty;
    private bool _isLoading = true;

    private readonly DialogOptions _standardOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(AccountId))
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            // Fetch Plans, Incomes and Fixed expenses simultaneously.
            var plansTask = http.GetFromJsonAsync<List<DivisionPlanDTO>>($"api/plans/{AccountId}");
            var incomesTask = http.GetFromJsonAsync<List<IncomeDTO>>($"api/incomes/{AccountId}");
            var fixedExpensesTask = http.GetFromJsonAsync<List<FixedExpenseDTO>>($"api/fixed-expenses/{AccountId}");

            await Task.WhenAll(plansTask, incomesTask, fixedExpensesTask);
            _plans = await plansTask ?? new();
            _incomes = await incomesTask ?? new();
            _fixedExpenses = await fixedExpensesTask ?? new();

            var activePlan = _plans.FirstOrDefault(x => x.IsActive) ?? _plans.FirstOrDefault();
            _selectedPlanId = activePlan?.Id;

            if (_selectedPlanId != null)
            {
                Console.WriteLine($"Pockets: ");
                foreach (var pocket in activePlan?.Pockets!)
                {
                    Console.WriteLine(pocket.Name);
                }

                _pockets = activePlan?.Pockets ?? new();
            }
        }
        catch (Exception)
        {
            Snackbar.Add(L["error_loading_pockets"], Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPlanChanged(string newPlanId)
    {
        if (newPlanId == "CREATE_NEW")
        {
            await CreateNewPlan();
            return;
        }

        _selectedPlanId = newPlanId;
        var plan = _plans.FirstOrDefault(p => p.Id == _selectedPlanId);
        _pockets = plan?.Pockets ?? new();
    }

    private async Task CreateNewPlan()
    {
        // Always reset the select first so it doesn't stay stuck on "CREATE_NEW".
        var activePlan = _plans.FirstOrDefault(x => x.IsActive) ?? _plans.FirstOrDefault();
        _selectedPlanId = activePlan?.Id;

        var dialog = await DialogService.ShowAsync<AddDivisionPlanDialog>(L["add_new_plan"], _standardOptions);
        var result = await dialog.Result;
        if (result!.Canceled || result.Data is not string name || string.IsNullOrWhiteSpace(name)) return;

        try
        {
            var payload = new CreateDivisionPlanDTO { AccountId = AccountId ?? string.Empty, Name = name };
            var response = await http.PostAsJsonAsync("api/plans", payload);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(L["plan_created"], Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add(L["error_creating_plan"], Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add(L["error_creating_plan"], Severity.Error);
        }
    }

    private async Task DeletePlan(DivisionPlanDTO plan)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L["delete_plan_title"].ToString() },
            { x => x.ContentText, L["delete_plan_confirm_description"].ToString() }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["delete_plan_title"], parameters, _standardOptions);
        var result = await dialog.Result;
        if (result!.Canceled) return;

        var res = await http.DeleteAsync($"api/plans/{plan.Id}");
        if (res.IsSuccessStatusCode)
        {
            Snackbar.Add(L["item_deleted"], Severity.Success);
            await LoadData();
        }
        else
        {
            // Server returns a localization key as the body for known cases.
            var body = (await res.Content.ReadAsStringAsync()).Trim().Trim('"');
            var localized = string.IsNullOrWhiteSpace(body) ? L["delete_error"] : L[body];
            Snackbar.Add(localized, Severity.Error);
        }
    }

    private static string PlanLabel(DivisionPlanDTO plan)
    {
        var shortId = plan.Id.Length > 8 ? plan.Id[..8] + "…" : plan.Id;
        var name = string.IsNullOrWhiteSpace(plan.Name) ? "—" : plan.Name;
        return $"{name} ({shortId})";
    }

    private async Task AddPocket()
    {
        var parameters = new DialogParameters<AddPocketDialog>
        {
            { x => x.Currency, SelectedCurrency },
            { x => x.Model, new PocketDTO() },
            { x => x.PresentPockets, _pockets },
            { x => x.Incomes, DistributableMoney },
        };

        var dialog = await DialogService.ShowAsync<AddPocketDialog>(L["add_pocket"], parameters, _standardOptions);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not PocketDTO newPocket) return;

        // Ask from which date+time the new pocket should be active.
        // SelectDateTimeDialog captures an exact timestamp so that two operations in the
        // same month never collide on the same ActiveFrom value.
        var monthParameters = new DialogParameters<SelectDateTimeDialog>
        {
            { x => x.Title, L["select_allow_from_title"].ToString() },
            { x => x.Description, L["select_allow_from_description"].ToString() },
        };

        var monthDialog = await DialogService.ShowAsync<SelectDateTimeDialog>(L["select_allow_from_title"], monthParameters, _standardOptions);
        var monthResult = await monthDialog.Result;

        if (monthResult.Canceled || monthResult.Data is not DateTime allowFrom) return;

        var payload = new CreatePocketDTO { Name = newPocket.Name, Ration = newPocket.Ration };
        var allowFromStr = Uri.EscapeDataString(allowFrom.ToString("o"));
        var response = await http.PostAsJsonAsync($"api/pockets/{_selectedPlanId}?allowFrom={allowFromStr}", payload);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(L["save_success"], Severity.Success);
            await LoadData();
        }
        else Snackbar.Add($"{L["save_error_for"]} {newPocket.Name}", Severity.Error);
    }

    private async Task EditPocket(PocketDTO pocket)
    {
        var modelCopy = new PocketDTO { Id = pocket.Id, Name = pocket.Name, Ration = pocket.Ration };

        var editParameters = new DialogParameters<AddPocketDialog>
        {
            { x => x.Currency, SelectedCurrency },
            { x => x.Model, modelCopy },
            { x => x.PresentPockets, _pockets },
            { x => x.Incomes, DistributableMoney },
        };

        var editDialog = await DialogService.ShowAsync<AddPocketDialog>(L["edit_pocket"], editParameters, _standardOptions);
        var editResult = await editDialog.Result;

        if (editResult.Canceled || editResult.Data is not PocketDTO updated) return;

        // Ask from which month the change should take effect
        var monthParameters = new DialogParameters<SelectDateTimeDialog>
        {
            { x => x.Title, L["select_allow_from_title"].ToString() },
            { x => x.Description, L["select_allow_from_description"].ToString() },
        };

        var dateTimeDialog = await DialogService.ShowAsync<SelectDateTimeDialog>(L["select_allow_from_title"], monthParameters, _standardOptions);
        var dateTimeResult = await dateTimeDialog.Result;

        if (dateTimeResult.Canceled || dateTimeResult.Data is not DateTime allowFrom) return;

        var allowFromStr = Uri.EscapeDataString(allowFrom.ToString("o"));
        var response = await http.PutAsJsonAsync($"api/pockets?allowFrom={allowFromStr}", updated);
        if (response.IsSuccessStatusCode)
        {
            pocket.Name = updated.Name;
            pocket.Ration = updated.Ration;
            Snackbar.Add(L["save_success"], Severity.Success);
            await LoadData();
        }
        else Snackbar.Add(L["save_error"], Severity.Error);
    }

    private async Task DeletePocket(PocketDTO pocket)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L["delete_pocket_title"] },
            { x => x.ContentText, L["delete_pocket_confirm_description"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["delete_pocket_title"], parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var response = await http.DeleteAsync($"api/pockets/{pocket.Id}");
            if (response.IsSuccessStatusCode)
            {
                // _pockets.Remove(pocket);
                Snackbar.Add(L["item_deleted"], Severity.Success);
                await LoadData();
            }
            else Snackbar.Add(L["delete_error"], Severity.Error);
        }
    }

    private async Task ActivatePlan()
    {
        var dateTimeParameters = new DialogParameters<SelectDateTimeDialog>
        {
            { x => x.Title, L["select_allow_from_title"].ToString() },
            { x => x.Description, L["select_allow_from_description"].ToString() },
        };

        var dateTimeDialog = await DialogService.ShowAsync<SelectDateTimeDialog>(L["select_allow_from_title"], dateTimeParameters, _standardOptions);
        var dateTimeResult = await dateTimeDialog.Result;

        if (dateTimeResult.Canceled || dateTimeResult.Data is not DateTime allowFrom) return;

        var allowFromStr = Uri.EscapeDataString(allowFrom.ToString("o"));
        var res = await http.PostAsync($"/api/plans/{_selectedPlanId}/activate?activateFrom={allowFromStr}", null);
        if (res.IsSuccessStatusCode)
        {
            Snackbar.Add(L["plan_activated"], Severity.Success);
            await LoadData();
        }
        else
        {
            Snackbar.Add(L["plan_activate_error"], Severity.Error); //TODO: better explanation...
        }
    }

}