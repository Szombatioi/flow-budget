@using global::DTO
@using FlowBudget.Client.Components.Helpers
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> L
@inject HttpClient Http

<div style="width: 100%; padding: 16px;">
    @if (_hasData)
    {
        <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_timeSeries"
                  ChartLabels="@_xAxisLabels" ChartOptions="_chartOptions"
                  Width="100%" Height="100%"
                  MatchBoundsToSize="true" />
    }
    else
    {
        <MudText Align="Align.Center" Typo="Typo.body2" Class="pa-8 mud-text-secondary">
            @L["chart_no_data"]
        </MudText>
    }
</div>

@code {
    [Parameter] public string PocketId { get; set; } = "";
    [Parameter] public ChartViewMode ViewMode { get; set; } = ChartViewMode.Weekly;
    [Parameter] public DateTime Date { get; set; } = DateTime.Today;

    private bool _hasData;
    private string[] _xAxisLabels = [];
    private List<ChartSeries<double>> _timeSeries = [];
    private readonly BarChartOptions _chartOptions = new();

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(PocketId))
        {
            Snackbar.Add(L["pocket_empty_error"], Severity.Error);
            return;
        }

        DateTime firstDay, lastDay;
        List<DateTime> days;

        if (ViewMode == ChartViewMode.Weekly)
        {
            var diff = (7 + (Date.DayOfWeek - DayOfWeek.Monday)) % 7;
            firstDay = Date.AddDays(-diff).Date;
            lastDay = firstDay.AddDays(6);
            days = GetDaysInRange(firstDay, lastDay);
            _xAxisLabels = days.Select(d => d.DayOfWeek.ToString()).ToArray();
        }
        else
        {
            firstDay = new DateTime(Date.Year, Date.Month, 1);
            lastDay = firstDay.AddMonths(1).AddDays(-1);
            days = GetDaysInRange(firstDay, lastDay);
            _xAxisLabels = days.Select(d => d.ToString("MM.dd")).ToArray();
            _chartOptions.XAxisLabelRotation = 60;
        }

        var res = await Http.GetFromJsonAsync<List<TimeSeriesItemDTO>>(
            $"api/daily-expenses/{PocketId}/time-series?from={firstDay:yyyy-MM-dd}&to={lastDay:yyyy-MM-dd}") ?? [];

        if (res.Count == 0)
        {
            _hasData = false;
            return;
        }
        
        var data = TimeSeriesAggregator.AggregateByDay(res, days);

        _timeSeries =
        [
            new ChartSeries<double> { Name = L["chart_daily_spending"], Data = data }
        ];

        _hasData = true;
    }

    private List<DateTime> GetDaysInRange(DateTime start, DateTime end)
    {
        return Enumerable.Range(0, (end - start).Days + 1)
            .Select(day => start.AddDays(day))
            .ToList();
    }
}
