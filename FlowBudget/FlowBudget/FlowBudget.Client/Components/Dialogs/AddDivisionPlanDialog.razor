@inject IStringLocalizer<SharedResources> L

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5"><b>@L["add_new_plan"]</b></MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudTextField T="string"
                          @bind-Value="_name"
                          Label="@L["division_plan_name_label"]"
                          Required="true"
                          RequiredError="@L["field_required"]"
                          Variant="Variant.Outlined"
                          MaxLength="100"
                          Immediate="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@(!_isValid)"
                   OnClick="Submit">@L["create"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private bool _isValid;
    private string _name = string.Empty;

    private void Submit() => MudDialog.Close(DialogResult.Ok(_name.Trim()));
    private void Cancel() => MudDialog.Cancel();
}
