@using global::DTO
@inject IStringLocalizer<SharedResources> L

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5"><b>@L["edit_account"]</b></MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudTextField T="string"
                          Label="@L["account_name"]"
                          @bind-Value="_name"
                          Required="true"
                          RequiredError="@L["field_required"]"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal" 
                          Immediate="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@(!_isValid)"
                   OnClick="Submit">@L["save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public AccountDTO Account { get; set; } = default!;

    private MudForm _form = null!;
    private bool _isValid;
    private string _name = string.Empty;

    protected override void OnInitialized()
    {
        _name = Account.Name;
        _isValid = !string.IsNullOrWhiteSpace(_name);
    }

    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(new UpdateAccountDTO { Name = _name }));
    }

    private void Cancel() => MudDialog.Cancel();
}
