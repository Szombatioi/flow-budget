@using MudBlazor.Utilities
<MudPaper Class="pa-6"
          Elevation="@(IsSelected ? 2 : 0)"
          Style=@($"position: relative; cursor: pointer; border-radius: 16px; user-select: none; transition: border-color 150ms, box-shadow 150ms; border: 2px solid {(IsSelected ? "var(--mud-palette-primary)" : "var(--mud-palette-lines-default)")};")
          @onclick="HandleClick">
    
    <div style="position: absolute; top: 12px; right: 12px;">
        <MudIcon Icon="@(IsSelected ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.RadioButtonUnchecked)"
                 Color="@(IsSelected ? Color.Success : Color.Default)"
                 Size="Size.Small"
                 Style="@(IsSelected ? null : "opacity: 0.3;")" />
    </div>
    
    <div class="d-flex justify-center mb-3">
        <div style="background-color: var(@("--mud-palette-primary"));@IconDiscStyle" >
            <MudIcon Icon="@Icon" Size="Size.Medium" Style="color: white;" />
        </div>
    </div>

    @* Title *@
    <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight: 700;">
        @Title
    </MudText>

    @* Description (optional) *@
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <MudText Typo="Typo.caption"
                 Align="Align.Center"
                 Class="mud-text-secondary mt-1"
                 Style="display: block;">
            @Description
        </MudText>
    }
</MudPaper>

@code {
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }

    [Parameter] public EventCallback<string> OnSelected { get; set; }
    

    private string IconDiscStyle =>
        $"width: 56px; height: 56px; border-radius: 50%;" +
        "display: flex; align-items: center; justify-content: center;";

    private async Task HandleClick()
    {
        if (OnSelected.HasDelegate)
            await OnSelected.InvokeAsync(Title);
    }
}
