@inject IStringLocalizer<SharedResources> L
@using DTO
@using FlowBudget.Client.Components.Dialogs
@using global::DTO
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject HttpClient http

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-6">
        
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">
            <MudIcon Icon=@Icons.Material.Filled.MoneyOff Class="mx-1" /><b>@L["fixed_expenses_title"]</b>
        </MudText>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
        }
        else
        {
            <MudList T="string" Clickable="false" Class="pb-2">
                @foreach (var budget in _fixedExpenses)
                {
                    <MudListItem>
                        <MudGrid Items="12" Class="align-center">
                            <MudItem xs="4">
                                <MudText Typo="Typo.body1">@budget.Name</MudText>
                            </MudItem>
                
                            <MudItem xs="4">
                                <MudText Typo="Typo.body1">
                                    @budget.Amount.ToString("N0") @SelectedCurrency
                                </MudText>
                            </MudItem>

                            <MudItem xs="4" Class="d-flex justify-end">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                               OnClick="@(() => EditFE(budget))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Color="Color.Error" 
                                               OnClick="@(() => DeleteFE(budget))" />
                            </MudItem>
                        </MudGrid>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>

            @* Total Section *@
            <MudText Typo="Typo.subtitle1">
                <b>@L["total_fixed_expenses"]</b>
            </MudText>
            <MudPaper Elevation="0" Class="p-2" Style="background-color: #2c3034; color: white;">
                <MudText Typo="Typo.h6"><b>@_fixedExpenses.Sum(x => x.Amount).ToString("N0") @SelectedCurrency</b></MudText>
            </MudPaper>
            
            <MudStack Row="true" Justify="Justify.FlexStart" Class="mt-6">
                <MudButton Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.Add" 
                           Variant="Variant.Text"
                           Size="Size.Small"
                           OnClick="AddFE">
                    @L["add_fixed_expense"]
                </MudButton>
            </MudStack>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public string? AccountId { get; set; }
    
    private List<FixedExpenseDTO> _fixedExpenses = new();
    private string SelectedCurrency = "HUF";
    private bool _isLoading = true;

    private readonly DialogOptions _standardOptions = new() 
    { 
        CloseOnEscapeKey = true, 
        MaxWidth = MaxWidth.Small, 
        FullWidth = true 
    };

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(AccountId))
        {
            await LoadFixedExpenses();
        }
    }
    
    private async Task LoadFixedExpenses()
    {
        _isLoading = true;
        try
        {
            // Update endpoint naming as per your backend convention
            var expenses = await http.GetFromJsonAsync<List<FixedExpenseDTO>>($"api/fixed-expenses/{AccountId}");
            _fixedExpenses = expenses ?? new();
        }
        catch (Exception)
        {
            Snackbar.Add(L["error_loading_fixed_expenses"], Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddFE()
    {
        var parameters = new DialogParameters<AddFixedExpenseDialog>
        {
            { x => x.Currency, SelectedCurrency },
            { x => x.Model, new FixedExpenseDTO() }
        };

        var dialog = await DialogService.ShowAsync<AddFixedExpenseDialog>(L["add_fixed_expense"], parameters, _standardOptions);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is FixedExpenseDTO newExpense)
        {
            var payload = new CreateFixedExpenseDTO()
            {
                AccountId = AccountId,
                Name = newExpense.Name,
                Amount = newExpense.Amount
            };

            var response = await http.PostAsJsonAsync("api/fixed-expenses", payload);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(L["save_success"], Severity.Success);
                await LoadFixedExpenses();
            }
            else
            {
                Snackbar.Add(L["save_error"], Severity.Error);
            }
        }
    }

    private async Task EditFE(FixedExpenseDTO fixedExpense)
    {
        var modelCopy = new FixedExpenseDTO() { Id = fixedExpense.Id, Name = fixedExpense.Name, Amount = fixedExpense.Amount };

        var parameters = new DialogParameters<AddFixedExpenseDialog>
        {
            { x => x.Currency, SelectedCurrency },
            { x => x.Model, modelCopy }
        };

        var dialog = await DialogService.ShowAsync<AddFixedExpenseDialog>(L["edit_fixed_expense"], parameters, _standardOptions);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not FixedExpenseDTO updated) return;

        // Ask when the change should take effect.  The exact date+time is stored so that
        // two edits in the same month get distinct ActiveFrom values and the latest wins.
        var dateParameters = new DialogParameters<SelectDateTimeDialog>
        {
            { x => x.Title, L["select_allow_from_title"].ToString() },
            { x => x.Description, L["select_allow_from_description"].ToString() },
        };

        var dateDialog = await DialogService.ShowAsync<SelectDateTimeDialog>(L["select_allow_from_title"], dateParameters, _standardOptions);
        var dateResult = await dateDialog.Result;

        if (dateResult.Canceled || dateResult.Data is not DateTime allowFrom) return;

        var allowFromStr = Uri.EscapeDataString(allowFrom.ToString("o"));
        var payload = new EditFixedExpenseDTO { Id = updated.Id, Name = updated.Name, Amount = updated.Amount };

        var response = await http.PutAsJsonAsync($"api/fixed-expenses?allowFrom={allowFromStr}", payload);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(L["save_success"], Severity.Success);
            // Reload so the list reflects the new version ID — without this the local
            // entry still holds the old ID and subsequent edit/delete targets the wrong row.
            await LoadFixedExpenses();
        }
        else
        {
            Snackbar.Add($"{L["save_error_for"]} {payload.Name}", Severity.Error);
        }
    }

    private async Task DeleteFE(FixedExpenseDTO fixedExpense)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L["delete_fixed_expense_title"] },
            { x => x.ContentText, L["delete_fixed_expense_confirm_description"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["delete_fixed_expense_title"], parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var response = await http.DeleteAsync($"api/fixed-expenses/{fixedExpense.Id}");
            if (response.IsSuccessStatusCode)
            {
                _fixedExpenses.Remove(fixedExpense);
                Snackbar.Add(L["item_deleted"], Severity.Success);
            }
            else
            {
                Snackbar.Add(L["delete_error"], Severity.Error);
            }
        }
    }
}