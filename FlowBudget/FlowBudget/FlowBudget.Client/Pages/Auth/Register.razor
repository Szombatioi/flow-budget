@page "/auth/register"
@layout EmptyLayout
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using FlowBudget.Client.Components.DTO
@using DTO
@inject HttpClient Http
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["register"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudCard Elevation="4" Class="pa-8 rounded-lg">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-4">@L["register"]</MudText>
        
        <EditForm Model="@_model" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />
            
            @* Unified Username Field *@
            <MudTextField Label="@L["username"]" 
                          @bind-Value="_model.Username" 
                          For="@(() => _model.Username)" 
                          Variant="Variant.Outlined" 
                          Class="mb-4" />

            <MudTextField Label="@L["email"]" 
                          @bind-Value="_model.Email" 
                          InputType="InputType.Email"
                          For="@(() => _model.Email)" 
                          Variant="Variant.Outlined" 
                          Class="mb-4" />

            <MudTextField Label="@L["password"]"
                          @bind-Value="_model.Password"
                          InputType="InputType.Password"
                          For="@(() => _model.Password)"
                          Variant="Variant.Outlined"
                          Class="mb-4" />

            <MudTextField Label="@L["repeat_password"]"
                          @bind-Value="_repeatPassword"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Error="@_passwordMismatch"
                          ErrorText="@L["password_mismatch"]"
                          Class="mb-6" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="_loading">
                @if (_loading) 
                { 
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/> 
                }
                @L["create_account"]
            </MudButton>
        </EditForm>
        
        <MudText Align="Align.Center" Class="mt-4">
            @L["already_have_account"] <MudLink Href="/auth/login">@L["login"]</MudLink>
        </MudText>
    </MudCard>
</MudContainer>

@code {
    private RegisterDTO _model = new();
    private string _repeatPassword = string.Empty;
    private bool _passwordMismatch;
    private bool _loading;

    private async Task HandleRegister()
    {
        _passwordMismatch = _model.Password != _repeatPassword;
        if (_passwordMismatch)
        {
            Snackbar.Add(L["password_mismatch"], Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/register", _model);
            
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(L["registration_success"], Severity.Success);
                Nav.NavigateTo("/", forceLoad: true); // Force load to refresh AuthState
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add(BuildRegisterError(body), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["error_connecting_to_server"], Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private string BuildRegisterError(string body)
    {
        var first = TryExtractFirstError(body);
        if (string.IsNullOrWhiteSpace(first))
            return L["registration_failed"].ToString();

        if (first.Contains("already taken", StringComparison.OrdinalIgnoreCase)
            || first.Contains("DuplicateUserName", StringComparison.OrdinalIgnoreCase)
            || first.Contains("DuplicateEmail", StringComparison.OrdinalIgnoreCase))
        {
            return L["user_already_exists"].ToString();
        }

        return $"{L["registration_failed"]}: {first}";
    }

    private static string? TryExtractFirstError(string body)
    {
        try
        {
            using var doc = JsonDocument.Parse(body);
            if (doc.RootElement.TryGetProperty("errors", out var errs) && errs.ValueKind == JsonValueKind.Array && errs.GetArrayLength() > 0)
                return errs[0].GetString();
        }
        catch
        {
            // Not JSON — fall back to the raw body below.
        }
        return body;
    }
}
