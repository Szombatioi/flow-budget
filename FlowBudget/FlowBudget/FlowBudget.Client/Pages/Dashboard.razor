@page "/"
@page "/{DateString?}"
@using DTO
@using FlowBudget.Client.Components.DTO
@using FlowBudget.Client.Components
@using FlowBudget.Client.Components.Dialogs
@using FlowBudget.Client.Components.Helpers
@using Microsoft.AspNetCore.Authorization
@inject IStringLocalizer<SharedResources> L
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav
@attribute [Authorize]

@if (UserDto is null || IsLoading)
{
    <div class="d-flex justify-center align-center">
        <MudProgressCircular Indeterminate="true"/>
    </div>
}
else if (IsError)
{
    <MudText Align="Align.Center">@L["page_error"]</MudText>
}
else if (UserDto.AccountIds.Count == 0)
{
    <MudContainer Class="d-flex justify-center align-center flex-column">
        <MudText Align="Align.Center">@L["no_accounts_yet"]</MudText>
        <MudText Align="Align.Center">
            @L["create_one_here"]:
            <MudLink Href="/accounts">
                @L["financial_accounts"]
            </MudLink>
        </MudText>
    </MudContainer>
}
else if (ActivePlan is null || DailyExpense is null)
{
    <MudContainer Class="d-flex justify-center align-center flex-column">
        <MudText Align="Align.Center">@L["no_plans_yet"]</MudText>
        <MudText Align="Align.Center">
            @L["create_one_here"]:
            <MudLink Href="/plan">
                @L["Planning & Setup"]
            </MudLink>
        </MudText>
    </MudContainer>
}
else
{
    <style>
        .no-hover-chart {
            pointer-events: none;
        }
    </style>

    <MudGrid Justify="Justify.Center" Spacing="0">

        @* Date navigation *@
        <MudItem xs="12" Class="align-center mb-2" Style="display: flex;">
            <div style="flex: 1; display: flex; flex-direction: column; align-items: flex-start;">
                <MudSelect T="AccountDTO"
                           Value="SelectedAccount"
                           ValueChanged="OnAccountChanged!"
                           Label="@L["select_account"]"
                           Variant="Variant.Outlined"
                           ToStringFunc="@(a => a?.Name ?? string.Empty)"
                           AnchorOrigin="Origin.BottomCenter"
                           Dense="true"
                           Style="max-width: 200px;">
                    @foreach (var account in _accounts)
                    {
                        <MudSelectItem Value="@account">@account.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="PocketDTO"
                           Value="SelectedPocket"
                           ValueChanged="OnPocketChanged!"
                           Label="@L["select_pocket"]"
                           Variant="Variant.Outlined"
                           ToStringFunc="@(p => p?.Name ?? string.Empty)"
                           AnchorOrigin="Origin.BottomCenter"
                           Dense="true"
                           Style="max-width: 200px;">
                    @foreach (var pocket in ActivePlan!.Pockets)
                    {
                        <MudSelectItem Value="@pocket">@pocket.Name</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div style="flex: 0 0 auto; display: flex; flex-direction: column; align-items: center;">
                <div style="display: flex; align-items: center;">
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                   OnClick="@(() => NavigateToDay(SelectedDate.AddDays(-1)))"
                                   Size="Size.Medium"
                                   aria-label="@L["previous_day"]"/>
                    <MudText Typo="Typo.h6" Style="min-width: 140px; text-align: center;">
                        @SelectedDate.ToString("yyyy-MM-dd")
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                   OnClick="@(() => NavigateToDay(SelectedDate.AddDays(1)))"
                                   Size="Size.Medium"
                                   aria-label="@L["next_day"]"/>
                </div>
                <MudButton OnClick="@(() => NavigateToDay(DateTime.Today))">@(L["today"])</MudButton>
            </div>
            <div style="flex: 1;"></div>
        </MudItem>

        @* Account + Pocket selectors *@
        @* <MudItem xs="12" Class="justify-center d-flex flex-column" Style="gap: 12px; border-color:  red; border-width: 1px"> *@
        @*      *@
        @* </MudItem> *@

        @* Chart + alert + expenditures — centered *@
        @* TODO can this be narrower to fit the two diagrams next to them? *@
        <MudItem xs="12" sm="8">
            <MudPaper Elevation="0" Class="no-hover-chart d-flex justify-center pa-2 mb-2">
                <MudChart T="double"
                          ChartType="ChartType.Donut"
                          Width="300px"
                          Height="300px"
                          ChartSeries="@( [SeriesData])"
                          ChartOptions="@Options"
                          Class="mb-0">
                    <CustomGraphics>
                        <text x="50%" y="50%" text-anchor="middle" class="mud-text-secondary"
                              style="font-weight: bold;">
                            <tspan x="50%" dy="-1.2em" style="font-size: 14px;">@L["todays_budget"]</tspan>
                            <tspan x="50%" dy="1.4em" style="font-size: 24px;">@((int)currentDisplayValue)%</tspan>
                            <tspan x="50%" dy="1.5em"
                                   style="font-size: 12px; font-weight: normal;">@((DailyExpense.StartAmount - DailyExpense.EoDAmount).ToString("0.##")) / @(DailyExpense.StartAmount.ToString("0.##")) @(L[$"currency_{ActivePlan.Account.CurrencyCode.ToLower()}_short"])</tspan>
                        </text>
                    </CustomGraphics>
                </MudChart>
            </MudPaper>

            @* Remaining budget alert *@
            <MudAlert Severity="Severity.Info" Class="my-2">
                <div>@(L["remaining_budget"]): <b>@(DailyExpense.EoDAmount.ToString("0.##")) @(L[$"currency_{ActivePlan.Account.CurrencyCode.ToLower()}_short"])</b></div>
                <div>@(L["relative_daily_limit"]): @(DailyExpense.RelativeBudget.ToString("0.##")) @(L[$"currency_{ActivePlan.Account.CurrencyCode.ToLower()}_short"])</div>
            </MudAlert>

            @* Expenditure list *@
            <MudPaper Elevation="2" Width="100%" MinHeight="64px" Class="p-4 my-2">
                <MudText Typo="Typo.h4" Align="Align.Center" Style="justify-self: center">
                    @L["expenditures"]
                </MudText>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div></div>
                    @if (DailyExpense.Expenditures.Count == 0)
                    {
                        <MudText Typo="Typo.body1" Align="Align.Center">@L["no_expenditures_yet"]</MudText>
                    }
                    <MudTooltip Text=@(L["add"]) Placement="Placement.Top">
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       OnClick="() => OpenDialog()">
                        </MudIconButton>
                    </MudTooltip>
                </div>
                
                @foreach (var e in DailyExpense.Expenditures)
                {
                    <ExpenditureListItem Expenditure=e
                                         OnDelete="DeleteExpenditure"
                                         OnEdit="EditExpenditure"
                                         OnClick="ShowExpenditureDetails"/>
                    if (DailyExpense.Expenditures.Last().Id != e.Id)
                    {
                        <MudDivider/>
                    }
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}


@code {
    [Parameter]
    public string? DateString { get; set; }

    private DateTime SelectedDate { get; set; } = DateTime.Today;
    
    [CascadingParameter] public UserBaseDTO? UserDto { get; set; }
    private double[] SeriesData = { 100, 0 };
    private double targetValue = 0;
    private double currentDisplayValue = 0;
    private bool _hasAnimated = false;
    private bool _isDataReady = false;

    private List<AccountDTO> _accounts = new();
    private AccountDTO? SelectedAccount { get; set; }
    private DivisionPlanDTO? ActivePlan { get; set; }
    private PocketDTO? SelectedPocket { get; set; }
    private DailyExpenseDTO? DailyExpense { get; set; }

    private bool IsLoading { get; set; } = true;
    private bool IsError { get; set; } = false;

    private ChartOptions Options = new ChartOptions();

    private List<CategoryDTO> _categories = new();

    private readonly DialogOptions _standardOptions = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDataReady && !_hasAnimated)
        {
            _hasAnimated = true;
            await AnimateChart();
        }
    }

    private async Task AnimateChart()
    {
        //TargetValue can be > 100, so we need to 
        for (int i = 0; i <= targetValue; i++)
        {
            currentDisplayValue = i; //%
            SeriesData = new double[] { Math.Max(100 - currentDisplayValue, 0.0), Math.Min(currentDisplayValue, 100.0) };
            Options.ChartPalette = new string[] { "#F5F5F5", GetProgressColor(currentDisplayValue) };
            StateHasChanged();

            //The delay amount is cut down if the deviation between 
            //the EoD and Start is too big (e.g. when we spend much more a day than the limit)
            int delay = targetValue <= 100
                ? 10
                : (int)Math.Max(1, 8 - 10 * Math.Log10(targetValue / 100.0));
            if (delay < 1) delay = 1;
            Console.WriteLine($"Delay: {delay}");
            await Task.Delay(delay);
        }
    }

    private string GetProgressColor(double value)
    {
        if (value < 50) return "#00ff00";
        if (value < 80) return "#ffff00";
        return "#ff0000";
    }

    // private List<ExpenditureDTO> expenditures { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        if (UserDto == null) { IsLoading = false; return; }
        if (UserDto.AccountIds.Count == 0) { IsLoading = false; return; }
        IsLoading = true;
        IsError = false;

        // Reset chart animation state so a new date re-runs the donut animation
        // instead of keeping the previously rendered value.
        _hasAnimated = false;
        _isDataReady = false;
        currentDisplayValue = 0;
        targetValue = 0;
        SeriesData = new double[] { 100, 0 };
        
        //Getting date from the url
        //If not specified, we use today
        if (DateString != null)
        {
            if (DateTime.TryParse(DateString, out var dt))
            {
                SelectedDate = dt;
            }
            else
            {
                Snackbar.Add(L["error_invalid_date"], Severity.Error);
                IsLoading = false;
                IsError = true;
                return;
            }
        }
        else
        {
            SelectedDate = DateTime.Today;
        }
        Console.WriteLine($"Date: {SelectedDate}");

        try
        {
            _accounts = await Http.GetFromJsonAsync<List<AccountDTO>>("api/accounts") ?? new();
            SelectedAccount ??= _accounts.FirstOrDefault();
        }
        catch (Exception)
        {
            Snackbar.Add(L["error_loading_accounts"], Severity.Error);
            IsLoading = false;
            IsError = true;
            return;
        }

        if (SelectedAccount == null)
        {
            IsLoading = false;
            return;
        }

        await LoadPlanForAccount(SelectedAccount.Id);

        try
        {
            var categories = await Http.GetFromJsonAsync<List<CategoryDTO>>("api/categories");
            _categories = categories ?? new();
        }
        catch (Exception)
        {
            // Non-critical: dialog will just show empty category list
        }

        if (SelectedPocket != null) await LoadDailyExpense();

        IsLoading = false;
    }

    private async Task LoadPlanForAccount(string accountId)
    {
        try
        {
            var res = await Http.GetFromJsonAsync<List<DivisionPlanDTO>>($"api/plans/{accountId}");
            var activePlan = (res ?? throw new InvalidOperationException()).SingleOrDefault(p => p.IsActive);
            ActivePlan = activePlan;
            SelectedPocket = ActivePlan?.Pockets.FirstOrDefault();
        }
        catch (Exception)
        {
            Snackbar.Add(L["error_load_active_division_plan"], Severity.Error);
            ActivePlan = null;
            SelectedPocket = null;
        }
    }

    private void NavigateToDay(DateTime date)
    {
        Nav.NavigateTo(date.Date == DateTime.Today ? "/" : $"/{date.FormatDate()}");
    }

    private async Task OnAccountChanged(AccountDTO newAccount)
    {
        SelectedAccount = newAccount;
        _hasAnimated = false;
        _isDataReady = false;
        DailyExpense = null;
        await LoadPlanForAccount(newAccount.Id);
        if (SelectedPocket != null) await LoadDailyExpense();
    }

    private async Task LoadDailyExpense()
    {
        Console.WriteLine("Load daily expense");
        try
        {
            if (SelectedPocket == null) throw new Exception(); //Catch below
            var res = await Http.GetFromJsonAsync<DailyExpenseDTO>($"api/daily-expenses/{SelectedPocket.Id}?date={SelectedDate.FormatDate()}");
            DailyExpense = res;

            var spent = DailyExpense.Expenditures.Sum(ex => ex.Price);
            var start = DailyExpense.StartAmount;

            if (start <= 0)
            {
                // StartAmount is zero or negative — already in debt before spending anything.
                // A ratio is meaningless here (there is no positive budget to divide against),
                // so always show 100% (fully red). The exact figures are visible as text.
                targetValue = 100.0;
            }
            else
            {
                // Normal case: what fraction of today's allowed budget has been spent.
                // Can exceed 100 if the user overspent (e.g. 150% = spent 1.5× the budget).
                targetValue = (double)(spent / start * 100);
            }
            _isDataReady = true;
            StateHasChanged();
        }
        catch (Exception)
        {
            Snackbar.Add(L["error_load_daily_expense"], Severity.Error);
        }
    }

    private async Task OnPocketChanged(PocketDTO newPocket)
    {
        SelectedPocket = newPocket;
        _hasAnimated = false;
        _isDataReady = false;
        await LoadDailyExpense();
    }

    private async Task ShowExpenditureDetails(ExpenditureDTO expenditure)
    {
        var parameters = new DialogParameters<ExpenditureDetailsDialog>
        {
            { x => x.Expenditure, expenditure }
        };
        await DialogService.ShowAsync<ExpenditureDetailsDialog>(L["expenditure_details"], parameters, _standardOptions);
    }

    private async Task EditExpenditure(ExpenditureDTO expenditure)
    {
        var parameters = new DialogParameters<EditExpenditureDialog>
        {
            { x => x.Expenditure, expenditure },
            { x => x.Currency, ActivePlan?.Account.CurrencyCode }
        };

        var dialog = await DialogService.ShowAsync<EditExpenditureDialog>(L["edit_expenditure"], parameters, _standardOptions);
        var result = await dialog.Result;

        if (result!.Canceled) return;

        var payload = (UpdateExpenditureDTO)result.Data!;
        var response = await Http.PutAsJsonAsync($"api/expenditures/{expenditure.Id}", payload);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(L["save_success"], Severity.Success);
            await LoadDailyExpense();
            await AnimateChart();
        }
        else
        {
            Snackbar.Add(L["save_error"], Severity.Error);
        }
    }

    private async Task DeleteExpenditure(ExpenditureDTO expenditure)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, L["delete_expenditure_title"] },
            { x => x.ContentText, L["delete_expenditure_confirm_description"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["delete_expenditure_title"], parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var response = await Http.DeleteAsync($"api/expenditures/{expenditure.Id}");
            if (response.IsSuccessStatusCode)
            {
                DailyExpense!.Expenditures.Remove(expenditure);
                Snackbar.Add(L["item_deleted"], Severity.Success);
                await LoadDailyExpense();
                await AnimateChart();
            }
            else
            {
                Snackbar.Add(L["delete_error"], Severity.Error);
            }
        }
    }

    private async Task OpenDialog()
    {
        Console.WriteLine("Open dialog");
        var parameters = new DialogParameters<AddExpenseDialog>
        {
            { x => x.Categories, _categories },
            { x => x.Pockets, ActivePlan?.Pockets ?? new() },
            { x => x.Currency, ActivePlan?.Account.CurrencyCode },
            { x => x.Date, SelectedDate },
            { x => x.DefaultPocketId, SelectedPocket.Id },
            { x => x.HasApiKey, UserDto?.HasApiKey ?? false }
        };

        var dialog = await DialogService.ShowAsync<AddExpenseDialog>(L["record_new_transaction"], parameters, _standardOptions);
        var result = await dialog.Result;

        if (!result!.Canceled)
        {
            var payloads = (List<CreateExpenditureDTO>)result.Data!;
            var savedCount = 0;
            foreach (var payload in payloads)
            {
                try
                {
                    var targetPocketId = payload.PocketId ?? SelectedPocket!.Id;
                    var res = await Http.PostAsJsonAsync($"api/expenditures/{targetPocketId}", payload);
                    if (res.IsSuccessStatusCode)
                        savedCount++;
                    else
                        Snackbar.Add($"{L["save_error_for"]} {payload.Name}", Severity.Error);
                }
                catch
                {
                    Snackbar.Add($"{L["save_error_for"]} {payload.Name}", Severity.Error);
                }
            }

            if (savedCount > 0)
            {
                Snackbar.Add(payloads.Count == 1
                    ? L["save_success"]
                    : $"{savedCount}/{payloads.Count} {L["items_saved"]}", Severity.Success);
                await LoadDailyExpense();
                await AnimateChart();
            }
        }
    }

}
