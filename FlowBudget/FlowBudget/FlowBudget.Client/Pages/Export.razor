@page "/export"
@using global::DTO
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using FlowBudget.Client.Components
@attribute [Authorize]
@inject IStringLocalizer<SharedResources> L
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>@L["export_page_title"]</PageTitle>

<div class="pa-4">
    <MudText Typo="Typo.h3">@L["export_page_title"]</MudText>
    <MudText Typo="Typo.body1">@L["export_page_description"]</MudText>
</div>

@* Settings *@
<div class="w-100 d-flex justify-center align-center">
    <MudPaper Class="pa-4" MaxWidth="75%" Elevation="0">
        <MudGrid Spacing="2">
            @* Account selection *@
            <MudItem xs="12">
                <MudText Typo="Typo.h6" Style="text-transform: capitalize" Class="pa-2">@L["account"]</MudText>
                <MudSelect T="AccountDTO"
                           Value="_selectedAccount"
                           ValueChanged="OnAccountChanged"
                           Label="@L["select_account"]"
                           Variant="Variant.Outlined"
                           ToStringFunc="@(a => a?.Name ?? string.Empty)"
                           AnchorOrigin="Origin.BottomCenter"
                           Dense="true"
                           Style="max-width: 240px;">
                    @foreach (var account in _accounts)
                    {
                        <MudSelectItem Value="@account">@account.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            @* Categories *@
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Style="text-transform: capitalize" Class="pa-2">@L["category"]</MudText>
                <div class="d-flex flex-wrap pa-2" style="gap: 8px;">
                    <MudChip T="string"
                             Color="@(_allCategories ? Color.Primary : Color.Default)"
                             Variant="@(_allCategories ? Variant.Filled : Variant.Outlined)"
                             OnClick="ToggleAllCategories">
                        @L["all"]
                    </MudChip>
                    @foreach (var cat in _categories)
                    {
                        var selected = !_allCategories && _selectedCategories.ContainsKey(cat.Id);
                        <MudChip T="string"
                                 Color="@(selected ? Color.Primary : Color.Default)"
                                 Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                                 OnClick="@(() => ToggleCategory(cat))">
                            @(cat.IsSystem ? L[cat.DisplayName].ToString() : cat.DisplayName)
                        </MudChip>
                    }
                </div>
            </MudItem>

            @* Pockets *@
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Style="text-transform: capitalize" Class="pa-2">@L["pocket"]</MudText>
                <div class="d-flex flex-wrap pa-2" style="gap: 8px;">
                    @foreach (var pocket in _pockets)
                    {
                        var selected = _selectedPockets.ContainsKey(pocket.Id);
                        <MudChip T="string"
                                 Color="@(selected ? Color.Primary : Color.Default)"
                                 Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                                 OnClick="@(() => TogglePocket(pocket))">
                            @pocket.Name
                        </MudChip>
                    }
                </div>
            </MudItem>

            @* Date range *@
            <MudItem xs="12">
                <MudText Typo="Typo.h6" Style="text-transform: capitalize" Class="pa-2">@L["date"]</MudText>
                <div class="d-flex justify-space-between align-center flex-wrap pa-2" style="gap: 12px;">
                    <div class="d-flex" style="gap: 12px;">
                        <MudDatePicker Label="@L["from"]"
                                       @bind-Date="_fromDate"
                                       Variant="Variant.Outlined"
                                       PickerVariant="PickerVariant.Inline"/>
                        <MudDatePicker Label="@L["to"]"
                                       @bind-Date="_toDate"
                                       Variant="Variant.Outlined"
                                       PickerVariant="PickerVariant.Inline"/>
                    </div>
                    <div>
                        <MudButton Variant="Variant.Outlined"
                                   OnClick="@(() => ApplyDatePreset(DatePreset.Last30Days))">
                            @L["expenses_last_30_days"]
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   OnClick="@(() => ApplyDatePreset(DatePreset.ThisQuarter))">
                            @L["export_this_quarter"]
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   OnClick="@(() => ApplyDatePreset(DatePreset.LastYear))">
                            @L["export_last_year"]
                        </MudButton>
                    </div>
                </div>
            </MudItem>

            @* Separator — only relevant for TXT *@
            @if (_selectedFormat == "TXT")
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Style="text-transform: capitalize" Class="pa-2">@L["separator"]</MudText>
                    <div class="pa-2">
                        <MudTextField T="string"
                                      @bind-Value="_separator"
                                      Placeholder="|"
                                      HelperText="@L["define_separator"]"
                                      Variant="Variant.Outlined"
                                      MaxLength="3"
                                      Style="max-width: 200px;" />
                    </div>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>
</div>

@* Format *@
<div style="width: 100%;" class="d-flex flex-column justify-center align-center">
    <div style="max-width: 75%; align-self: start;">
        <MudText Typo="Typo.h6" Class="pt-4 pb-2">@L["export_format"]</MudText>
    </div>
    <MudGrid Class="pa-4" Style="max-width: 75%;" Spacing="2">
        @foreach (var export in ExportFormats)
        {
            <MudItem xs="6" md="3">
                <SelectablePaper Title="@export.Title"
                                 Icon="@export.Icon"
                                 Description="@L[$"export_{export.Title.ToLower()}_description"]"
                                 IsSelected="@(_selectedFormat == export.Title)"
                                 OnSelected="OnFormatSelected"/>
            </MudItem>
        }
    </MudGrid>
</div>

<div class="d-flex justify-center align-center pa-6">
    @if (_exporting)
    {
        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
    }
    else
    {
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Class="px-8 py-6"
                   Style="border-radius: 8px"
                   Disabled="@(_selectedFormat is null || _exporting)"
                   OnClick="ExportData">

            @L["export_data_button"]
        </MudButton>
    }
</div>

@code {
    [CascadingParameter] public UserBaseDTO? UserDto { get; set; }

    private string? _selectedFormat;

    private List<AccountDTO> _accounts = new();
    private AccountDTO? _selectedAccount;

    private List<CategoryDTO> _categories = new();
    private Dictionary<string, CategoryDTO> _selectedCategories = new();
    private bool _allCategories = true;

    private List<PocketDTO> _pockets = new();
    private Dictionary<string, PocketDTO> _selectedPockets = new();

    private DateTime? _fromDate = DateTime.Today.AddDays(-30);
    private DateTime? _toDate = DateTime.Today;

    private bool _exporting;
    private bool _initialized;

    private string? _separator { get; set; }


    private enum DatePreset
    {
        Last30Days,
        ThisQuarter,
        LastYear
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_initialized || UserDto is null) return;
        _initialized = true;
        await LoadFilters();
    }

    private async Task LoadFilters()
    {
        try
        {
            _categories = await Http.GetFromJsonAsync<List<CategoryDTO>>("api/categories") ?? new();
            _accounts = await Http.GetFromJsonAsync<List<AccountDTO>>("api/accounts") ?? new();
            _selectedAccount = _accounts.FirstOrDefault();

            if (_selectedAccount != null)
                await LoadPocketsForAccount(_selectedAccount.Id);
        }
        catch
        {
            Snackbar.Add(L["something_went_wrong"], Severity.Error);
        }
    }

    private async Task LoadPocketsForAccount(string accountId)
    {
        _pockets = new();
        try
        {
            var plans = await Http.GetFromJsonAsync<List<DivisionPlanDTO>>($"api/plans/{accountId}") ?? new();
            foreach (var pocket in plans.SelectMany(p => p.Pockets))
            {
                if (_pockets.All(p => p.Id != pocket.Id))
                    _pockets.Add(pocket);
            }
        }
        catch
        {
            Snackbar.Add(L["something_went_wrong"], Severity.Error);
        }
        
        _selectedPockets = _pockets.ToDictionary(p => p.Id);
    }

    private async Task OnAccountChanged(AccountDTO account)
    {
        _selectedAccount = account;
        await LoadPocketsForAccount(account.Id);
    }

    private void OnFormatSelected(string title) => _selectedFormat = title;

    private void ToggleAllCategories()
    {
        _allCategories = true;
        _selectedCategories.Clear();
    }

    private void ToggleCategory(CategoryDTO category)
    {
        _allCategories = false;
        if (!_selectedCategories.Remove(category.Id))
            _selectedCategories[category.Id] = category;
        
        if (_selectedCategories.Count == 0)
            _allCategories = true;
    }

    private void TogglePocket(PocketDTO pocket)
    {
        if (!_selectedPockets.Remove(pocket.Id))
            _selectedPockets[pocket.Id] = pocket;
    }

    private void ApplyDatePreset(DatePreset preset)
    {
        var today = DateTime.Today;
        switch (preset)
        {
            case DatePreset.Last30Days:
                _fromDate = today.AddDays(-30);
                _toDate = today;
                break;
            case DatePreset.ThisQuarter:
                var qStartMonth = ((today.Month - 1) / 3) * 3 + 1;
                _fromDate = new DateTime(today.Year, qStartMonth, 1);
                _toDate = today;
                break;
            case DatePreset.LastYear:
                _fromDate = new DateTime(today.Year - 1, 1, 1);
                _toDate = new DateTime(today.Year - 1, 12, 31);
                break;
        }
    }
    
    private async Task ExportData()
    {
        if (_selectedFormat is null) return;
        if (_selectedPockets.Count == 0)
        {
            Snackbar.Add(L["select_at_least_one_pocket"], Severity.Warning);
            return;
        }

        _exporting = true;
        try
        {
            var payload = new ExportParameterDTO
            {
                ExportingFormat = _selectedFormat,
                Categories = _allCategories ? new List<CategoryDTO>() : _selectedCategories.Values.ToList(),
                Pockets = _selectedPockets.Values.ToList(),
                FromDate = _fromDate ?? DateTime.Today.AddYears(-1),
                ToDate = _toDate ?? DateTime.Today,
                Separator = _separator,
                CurrencyName = _selectedAccount?.CurrencyCode ?? string.Empty
            };

            var res = await Http.PostAsJsonAsync("api/expenditures/export", payload);
            if (!res.IsSuccessStatusCode)
            {
                Snackbar.Add(L["something_went_wrong"], Severity.Error);
                return;
            }

            // Extract the filename
            var fileName = res.Content.Headers.ContentDisposition?.FileNameStar
                           ?? res.Content.Headers.ContentDisposition?.FileName?.Trim('"')
                           ?? $"flowbudget-export.{_selectedFormat.ToLowerInvariant()}";
            
            await using var stream = await res.Content.ReadAsStreamAsync();
            using var streamRef = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);

            Snackbar.Add(L["export_started"], Severity.Success);
        }
        catch
        {
            Snackbar.Add(L["something_went_wrong"], Severity.Error);
        }
        finally
        {
            _exporting = false;
        }
    }

    private record ExportFormat
    {
        public string Title { get; set; } = string.Empty;
        public string Icon { get; set; } = string.Empty;
    }

    private List<ExportFormat> ExportFormats = new()
    {
        new() { Title = "TXT", Icon = Icons.Material.Filled.Code },
        new() { Title = "JSON", Icon = Icons.Material.Filled.Code },
        new() { Title = "CSV", Icon = Icons.Material.Filled.TableChart },
        new() { Title = "EXCEL", Icon = Icons.Material.Filled.TableChart },
    };


}
