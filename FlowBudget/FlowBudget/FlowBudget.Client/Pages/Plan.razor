@page "/plan"
@using DTO
@using FlowBudget.Client.Components
@inject HttpClient http
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["nav_planning_and_setup"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_accounts.Count == 0)
    {
        <MudAlert Severity="Severity.Info">@L["no_accounts_found"]</MudAlert>
    }
    else
    {
        <MudSelect T="AccountDTO"
                   Value="_selectedAccount"
                   ValueChanged="OnAccountChanged"
                   Label="@L["select_account"]"
                   Variant="Variant.Outlined"
                   ToStringFunc="@(a => a?.Name ?? string.Empty)"
                   AnchorOrigin="Origin.BottomCenter"
                   Dense="true"
                   Class="mb-4"
                   Style="max-width: 240px;">
            @foreach (var account in _accounts)
            {
                <MudSelectItem Value="@account">@account.Name (@account.CurrencyCode)</MudSelectItem>
            }
        </MudSelect>

        @if (_selectedAccount != null)
        {
            <MudStack Spacing="6">
                @* Pass the ID and currency to all children *@
                <IncomePaper AccountId="@_selectedAccount.Id" SelectedCurrency="@_selectedAccount.CurrencyCode" />

                <FixedExpensesPaper AccountId="@_selectedAccount.Id" SelectedCurrency="@_selectedAccount.CurrencyCode" />

                <PocketsPaper AccountId="@_selectedAccount.Id" SelectedCurrency="@_selectedAccount.CurrencyCode" />

                <CategoryPaper />
            </MudStack>
        }
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private List<AccountDTO> _accounts = new();
    private AccountDTO? _selectedAccount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _accounts = await http.GetFromJsonAsync<List<AccountDTO>>("api/accounts") ?? new();
            _selectedAccount = _accounts.FirstOrDefault();
        }
        catch (Exception)
        {
            Snackbar.Add(L["error_loading_accounts"], Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnAccountChanged(AccountDTO account)
    {
        _selectedAccount = account;
    }
}
