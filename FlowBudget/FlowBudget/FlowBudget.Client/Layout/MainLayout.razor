@inherits LayoutComponentBase
@using System.Security.Claims
@using DTO
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthProvider
@attribute [Authorize]
@inject HttpClient http
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager nav
@inject ISnackbar Snackbar

@* Optional: @inject UserManager<ApplicationUser> UserManager *@

<MudThemeProvider Theme="theme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<style>
    /* Remove the default shadow from the AppBar to let it blend */
    .mud-appbar {
        border-bottom: 1px solid rgba(0, 0, 0, 0.05); /* Subtle separator instead of shadow */
    }

    /* Fix the Drawer shadow to only cast to the right */
    .mud-drawer-fixed {
        box-shadow: 4px 0 8px -3px rgba(0, 0, 0, 0.1);
        border-right: 1px solid rgba(0, 0, 0, 0.05);
    }

    /* Ensure the mini-drawer icons are centered when collapsed */
    .mud-drawer-mini .mud-nav-link {
        justify-content: center;
        padding-left: 0;
    }
</style>

<MudLayout>
    @* Elevation 0 removes the bottom shadow that separates it from the drawer *@
    <MudAppBar Elevation="0" Class="border-b">
        @* <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" *@
        @*                Edge="Edge.Start" OnClick="ToggleDrawer"/> *@
        @* <MudText Typo="Typo.h6" Class="ml-3"><b>FlowBudget</b></MudText> *@
        @* <MudSpacer /> *@
        <MudText Typo="Typo.h4">@appBarTitle</MudText>
    </MudAppBar>

    @* ClipMode.Always ensures the AppBar stays 'above' the Drawer visually *@
    <MudDrawer @bind-Open="@_open"
               Variant="@DrawerVariant.Mini"
               ClipMode="DrawerClipMode.Never"
               Overlay="false"
               Elevation="0">
        <MudDrawerHeader Class="d-flex flex-column">
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudText Typo="Typo.h5">FlowBudget</MudText>
                <MudText Typo="Typo.subtitle1">@L["slogan"]</MudText>
            </MudHidden>
        </MudDrawerHeader>
        <MudNavMenu Class="mt-4 h-100 d-flex flex-column justify-space-between"
                    Style="background: transparent;">
            <div>
                <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Dashboard"
                            OnClick="@(() => PageChanged("nav_dashboard", "/"))">
                    @L["nav_dashboard"]
                </MudNavLink>
                <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.AccountBalanceWallet"
                            OnClick="@(() => PageChanged("nav_accounts", "/accounts"))">
                    @L["nav_accounts"]
                </MudNavLink>
                <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.SettingsSuggest"
                            OnClick="@(() => PageChanged("nav_planning_and_setup", "/plan"))">
                    @L["nav_planning_and_setup"]
                </MudNavLink>
                <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.BarChart"
                            OnClick="@(() => PageChanged("nav_statistics", "/statistics"))">
                    @L["nav_statistics"]
                </MudNavLink>
            </div>

            <div>
                <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.BarChart"
                            OnClick="@(() => Logout())">
                    @L["nav_logout"]
                </MudNavLink>
            </div>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <CascadingValue Value="UserDto">
            <MudContainer MaxWidth="MaxWidth.False" Class="mt-4 px-4">
                @Body
            </MudContainer>
        </CascadingValue>
    </MudMainContent>
</MudLayout>

@code {
    private ClaimsPrincipal? _currentUser;
    [CascadingParameter] private ClaimsPrincipal? User { get; set; }
    [CascadingParameter] public UserBaseDTO? UserDto { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; } // Use the Task version for better reliability

    private string appBarTitle = "Dashboard"; //TODO: make a dictionary with URL-title pairs and use them here (OnInitializedAsync method)
    private bool _open = true;
    private readonly bool _overlayAutoClose = false;

    private void ToggleDrawer()
    {
        // _open = !_open;
    }

    private const string LightPaletteGrey = "#F0F1F2";

    [CascadingParameter]
    public MudTheme theme { get; set; } = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Background = LightPaletteGrey,
            Surface = "#ffffff",       // MudPaper background — slightly darker than the page
            DrawerBackground = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            TextPrimary = "#454748",
            AppbarText = "#454748"
        },
        PaletteDark = new PaletteDark()
        {
            Background = "#032F64"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        // var authState = await AuthProvider.GetAuthenticationStateAsync();
        // _currentUser = authState.User;

        // If you need the full DB object (ApplicationUser):
        // _fullUser = await UserManager.GetUserAsync(_currentUser);


        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                // Use a try-catch for the specific API call
                try
                {
                    UserDto = await http.GetFromJsonAsync<UserBaseDTO>("api/user");
                    Console.WriteLine($"User loaded: {UserDto?.Id}");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"API Error: {ex.Message}");
                }
            }
        }
    }

    private void PageChanged(string title, string url)
    {
        appBarTitle = L[title];
        nav.NavigateTo(url);
        StateHasChanged();
    }

    private async Task Logout()
    {
        var res = await http.PostAsync("/api/auth/logout", null);
        if (res.IsSuccessStatusCode)
        {
            nav.NavigateTo("/auth/login");
        }
        else
        {
            Snackbar.Add(L["something_went_wrong"], Severity.Error);
        }
    }

}