@inherits LayoutComponentBase
@implements IDisposable
@using System.Security.Claims
@using DTO
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthProvider
@attribute [Authorize]
@inject HttpClient http
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager nav
@inject ISnackbar Snackbar
@inject ThemeService ThemeService

@* Optional: @inject UserManager<ApplicationUser> UserManager *@

<MudThemeProvider Theme="theme" IsDarkMode="@ThemeService.IsDarkMode"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<style>
    /* Remove the default shadow from the AppBar to let it blend */
    .mud-appbar {
        border-bottom: 1px solid rgba(0, 0, 0, 0.05); /* Subtle separator instead of shadow */
    }

    /* Fix the Drawer shadow to only cast to the right */
    .mud-drawer-fixed {
        box-shadow: 4px 0 8px -3px rgba(0, 0, 0, 0.1);
        border-right: 1px solid rgba(0, 0, 0, 0.05);
    }

    /* Ensure the mini-drawer icons are centered when collapsed */
    .mud-drawer-mini .mud-nav-link {
        justify-content: center;
        padding-left: 0;
    }
</style>

<MudLayout>
    @* Elevation 0 removes the bottom shadow that separates it from the drawer *@
    <MudAppBar Elevation="0" Class="border-b">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer"
                       aria-label="@L["toggle_navigation"]" />
        <MudText Typo="Typo.h4" Class="ml-3">@appBarTitle</MudText>
    </MudAppBar>

    @* ClipMode.Always ensures the AppBar stays 'above' the Drawer visually *@
    <MudDrawer @bind-Open="@_open"
               Variant="@DrawerVariant.Temporary"
               ClipMode="DrawerClipMode.Never"
               Overlay="true"
               Elevation="0">
        <MudDrawerHeader Class="d-flex flex-column">
            <MudText Typo="Typo.h5">FlowBudget</MudText>
            <MudText Typo="Typo.subtitle1">@L["slogan"]</MudText>
        </MudDrawerHeader>
        <AuthorizeView>
            <Authorized>
                <MudNavMenu Class="mt-4 h-100 d-flex flex-column justify-space-between"
                            Style="background: transparent;">
                    <div>
                        <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Filled.Dashboard"
                                    OnClick="@(() => PageChanged("nav_dashboard", "/"))">
                            @L["nav_dashboard"]
                        </MudNavLink>
                        <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Filled.AccountBalanceWallet"
                                    OnClick="@(() => PageChanged("nav_accounts", "/accounts"))">
                            @L["nav_accounts"]
                        </MudNavLink>
                        <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Filled.SettingsSuggest"
                                    OnClick="@(() => PageChanged("nav_planning_and_setup", "/plan"))">
                            @L["nav_planning_and_setup"]
                        </MudNavLink>
                        <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Filled.AttachMoney"
                                    OnClick="@(() => PageChanged("nav_expenses", "/expenses"))">
                            @L["nav_expenses"]
                        </MudNavLink>
                        <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Filled.Checklist"
                                    OnClick="@(() => PageChanged("nav_wishlist", "/wishlist"))">
                            @L["nav_wishlist"]
                        </MudNavLink>
                        <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Filled.BarChart"
                                    OnClick="@(() => PageChanged("nav_statistics", "/statistics"))">
                            @L["nav_statistics"]
                        </MudNavLink>
                    </div>

                    <div>
                        @if (_isAdmin)
                        {
                            <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                                        Icon="@Icons.Material.Filled.AdminPanelSettings"
                                        OnClick="@(() => PageChanged("nav_admin", "/admin"))">
                                @L["nav_admin"]
                            </MudNavLink>
                        }
                        <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Filled.Settings"
                                    OnClick="@(() => PageChanged("nav_settings", "/settings"))">
                            @L["nav_settings"]
                        </MudNavLink>
                        <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                                    Icon="@Icons.Material.Filled.Logout"
                                    OnClick="@(() => Logout())">
                            @L["nav_logout"]
                        </MudNavLink>
                    </div>
                </MudNavMenu>
            </Authorized>
            <NotAuthorized>
                <MudNavLink Class="p-1 ml-1" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Login"
                            OnClick="@(() => PageChanged("nav_login", "/auth/login"))">
                    @L["nav_login"]
                </MudNavLink>
            </NotAuthorized>
        </AuthorizeView>
    </MudDrawer>

    <MudMainContent>
        <CascadingValue Value="UserDto">
            <MudContainer MaxWidth="MaxWidth.False" Class="mt-4 px-4">
                @Body
            </MudContainer>
        </CascadingValue>
    </MudMainContent>
</MudLayout>

@code {
    private ClaimsPrincipal? _currentUser;
    [CascadingParameter] private ClaimsPrincipal? User { get; set; }
    private UserBaseDTO? UserDto { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; } // Use the Task version for better reliability

    private string appBarTitle = ""; //TODO: make a dictionary with URL-title pairs and use them here (OnInitializedAsync method)
    private bool _open;
    private bool _isAdmin;
    private readonly bool _overlayAutoClose = false;

    private void ToggleDrawer() => _open = !_open;

    private const string LightPaletteGrey = "#F0F1F2";

    [CascadingParameter]
    public MudTheme theme { get; set; } = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Background = LightPaletteGrey,
            Surface = "#ffffff",       // MudPaper background — slightly darker than the page
            DrawerBackground = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            TextPrimary = "#454748",
            AppbarText = "#454748"
        },
        PaletteDark = new PaletteDark()
        {
            Background = "#032F64"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        nav.LocationChanged += OnLocationChanged;
        ThemeService.OnThemeChanged += OnThemeChanged;
        await LoadUser();
    }

    private void OnThemeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await LoadUser();
        StateHasChanged();
    }

    private async Task LoadUser()
    {
        if (AuthStateTask == null) return;

        var authState = await AuthStateTask;
        if (authState.User.Identity?.IsAuthenticated != true) return;

        _isAdmin = authState.User.HasClaim("admin", "true");

        try
        {
            UserDto = await http.GetFromJsonAsync<UserBaseDTO>("api/user");
            Console.WriteLine($"User loaded: {UserDto?.Id}");
            ThemeService.SetDarkMode(UserDto?.Theme == "dark");
        }
        catch (HttpRequestException ex)
        {
            Console.WriteLine($"api/user failed ({(int?)ex.StatusCode}), redirecting to login.");
            if (!nav.Uri.Contains("/auth"))
                nav.NavigateTo("/auth/login", forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"API Error: {ex.Message}");
        }
    }

    public void Dispose()
    {
        nav.LocationChanged -= OnLocationChanged;
        ThemeService.OnThemeChanged -= OnThemeChanged;
    }

    private void PageChanged(string title, string url)
    {
        appBarTitle = L[title];
        _open = false;
        nav.NavigateTo(url);
        StateHasChanged();
    }

    private async Task Logout()
    {
        var res = await http.PostAsync("/api/auth/logout", null);
        if (res.IsSuccessStatusCode)
        {
            nav.NavigateTo("/auth/login");
        }
        else
        {
            Snackbar.Add(L["something_went_wrong"], Severity.Error);
        }
    }

}