@inherits LayoutComponentBase

<style>
    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        font-family: Roboto, sans-serif;
    }

    .auth-shell {
        display: flex;
        min-height: 100vh;
    }

    /* ── Left panel ─────────────────────────────────── */
    .auth-left {
        width: 38%;
        background: #0d1b3e;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 48px 40px;
        color: white;
        gap: 16px;
    }

    .auth-logo-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255,255,255,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin-bottom: 8px;
    }

    .auth-app-name {
        font-size: 32px;
        font-weight: 700;
        letter-spacing: -0.5px;
        margin: 0;
    }

    .auth-tagline {
        font-size: 14px;
        color: rgba(255,255,255,0.6);
        text-align: center;
        margin: 0;
    }

    /* ── Right panel ────────────────────────────────── */
    .auth-right {
        flex: 1;
        background: #f4f6f8;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
    }

    .auth-card {
        background: white;
        border-radius: 20px;
        padding: 48px 44px;
        width: 100%;
        max-width: 440px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    }

    .auth-card h2 {
        font-size: 26px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 6px 0;
    }

    .auth-subtitle {
        font-size: 14px;
        color: #6b7280;
        margin: 0 0 28px 0;
    }

    /* ── Form elements ──────────────────────────────── */
    .auth-field {
        display: flex;
        flex-direction: column;
        margin-bottom: 18px;
    }

    .auth-field-row {
        display: flex;
        gap: 12px;
        margin-bottom: 18px;
    }

    .auth-field-row .auth-field {
        flex: 1;
        margin-bottom: 0;
    }

    .auth-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        color: #6b7280;
        margin-bottom: 7px;
    }

    .auth-input {
        background: #f1f3f5;
        border: 1.5px solid transparent;
        border-radius: 10px;
        padding: 13px 16px;
        font-size: 14px;
        font-family: Roboto, sans-serif;
        color: #111827;
        outline: none;
        width: 100%;
        box-sizing: border-box;
        transition: border-color 0.15s, background 0.15s;
    }

    .auth-input:focus {
        background: #fff;
        border-color: #0d1b3e;
    }

    .auth-input::placeholder {
        color: #9ca3af;
    }

    /* ── Validation ─────────────────────────────────── */
    .validation-message {
        font-size: 12px;
        color: #dc2626;
        margin-top: 4px;
    }

    .auth-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        color: #dc2626;
        margin-bottom: 20px;
    }

    /* ── Label row (password + forgot) ─────────────── */
    .auth-label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 7px;
    }

    .auth-label-row a {
        font-size: 12px;
        font-weight: 600;
        color: #0d1b3e;
        text-decoration: none;
    }

    .auth-label-row a:hover {
        text-decoration: underline;
    }

    /* ── Remember me ────────────────────────────────── */
    .auth-remember {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
        font-size: 13px;
        color: #374151;
    }

    .auth-remember input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: #0d1b3e;
        cursor: pointer;
    }

    /* ── Submit button ──────────────────────────────── */
    .auth-btn {
        width: 100%;
        background: #0d1b3e;
        color: white;
        border: none;
        border-radius: 50px;
        padding: 15px;
        font-size: 15px;
        font-weight: 600;
        font-family: Roboto, sans-serif;
        cursor: pointer;
        transition: opacity 0.2s;
        margin-bottom: 20px;
    }

    .auth-btn:hover {
        opacity: 0.88;
    }

    /* ── Bottom link ────────────────────────────────── */
    .auth-bottom-link {
        text-align: center;
        font-size: 13px;
        color: #6b7280;
    }

    .auth-bottom-link a {
        font-weight: 700;
        color: #0d1b3e;
        text-decoration: none;
    }

    .auth-bottom-link a:hover {
        text-decoration: underline;
    }

    @@media (max-width: 640px) {
        .auth-left { display: none; }
        .auth-card { padding: 32px 24px; }
    }
</style>

<div class="auth-shell">
    <div class="auth-left">
        <div class="auth-logo-circle">💰</div>
        <p class="auth-app-name">FlowBudget</p>
        <p class="auth-tagline">Track your daily spending,<br/>stay in control of your budget.</p>
    </div>
    <div class="auth-right">
        <div class="auth-card">
            @Body
        </div>
    </div>
</div>
